      "html": "\n<div class=\"min-h-screen bg-[#010B13] text-white font-['Inconsolata'] selection:bg-[#39FF14] selection:text-[#010B13] overflow-x-clip\" data-kid=\"0\">\n  \n  <div class=\"fixed inset-0 pointer-events-none opacity-5\" data-kid=\"1\">\n    <div class=\"h-full w-full\" style=\"background-image: radial-gradient(#1560BD 1px, transparent 1px); background-size: 32px 32px;\" data-kid=\"2\"></div>\n  </div>\n\n  <main class=\"relative z-10 p-6 lg:p-8 max-w-[1600px] mx-auto\" data-kid=\"3\">\n    \n    <header class=\"dashboard-header flex flex-col md:flex-row justify-between items-start md:items-center border-b border-[#1560BD]/30 pb-6 mb-8 gap-4\" data-kid=\"4\">\n      <div class=\"flex items-center gap-5\" data-kid=\"5\">\n        <div class=\"w-12 h-12 bg-[#1560BD]/20 border border-[#1560BD]/40 flex items-center justify-center rounded-xs shadow-[0_0_15px_rgba(21,96,189,0.2)] relative overflow-hidden\" data-kid=\"6\">\n          <div class=\"absolute inset-0 bg-[#39FF14]/5 animate-pulse\" data-kid=\"7\"></div>\n          <i class=\"ti ti-terminal text-2xl text-[#1560BD] relative z-10\" data-kid=\"8\"></i>\n        </div>\n        <div data-kid=\"9\">\n          <h1 class=\"text-3xl lg:text-4xl font-black tracking-tighter uppercase flex items-center gap-3 drop-shadow-[0_0_10px_rgba(255,255,255,0.1)]\" data-kid=\"10\">\n            Admin Console <span class=\"text-blue-400 text-sm font-mono opacity-80\" data-kid=\"11\">SRV-NODE-01</span>\n          </h1>\n          <div class=\"flex items-center gap-4 text-xs text-blue-400/80 font-bold tracking-[0.2em] uppercase mt-2\" data-kid=\"12\">\n            <span data-kid=\"13\">Protocol: <span class=\"text-blue-300\" data-kid=\"14\">HTTPS/SECURE</span></span>\n            <span class=\"w-1 h-1 bg-blue-400/40 rounded-full\" data-kid=\"15\"></span>\n            <span data-kid=\"16\">Uptime: <span class=\"text-blue-300\" data-kid=\"17\">432:12:05</span></span>\n          </div>\n        </div>\n      </div>\n      \