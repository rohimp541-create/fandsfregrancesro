      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;700;800&family=Fira+Mono&display=swap');\n\n  :root {\n    --color-lemon: #FDEE00;\n    --color-white: #FFFFFF;\n    --color-onyx: #111111;\n    --color-green: #00FF40;\n  }\n\n  body {\n    margin: 0;\n    background-color: var(--color-lemon);\n    font-family: 'Space_Grotesk', sans-serif;\n    color: var(--color-onyx);\n    overflow-x: clip;\n  }\n\n  .brutalist-border {\n    border: 3px solid var(--color-onyx);\n  }\n\n  .brutalist-shadow {\n    box-shadow: 4px 4px 0px 0px var(--color-onyx);\n  }\n\n  /* Grid pattern for decorative elements */\n  .grid-bg {\n    background-image: radial-gradient(var(--color-onyx) 1px, transparent 1px);\n    background-size: 20px 20px;\n    opacity: 0.05;\n  }\n\n  /* Custom Scrollbar for Terminal */\n  .terminal-scroll::-webkit-scrollbar {\n    width: 12px;\n  }\n  .terminal-scroll::-webkit-scrollbar-track {\n    background: var(--color-onyx);\n  }\n  .terminal-scroll::-webkit-scrollbar-thumb {\n    background: var(--color-white);\n    border: 3px solid var(--color-onyx);\n  }\n\n  .font-anton { font-family: 'Anton', sans-serif; }\n  .font-mono { font-family: 'Fira Mono', monospace; }\n\n  /* Final Polish: Scanning effect for terminal */\n  .scanline {\n    width: 100%;\n    height: 100px;\n    z-index: 5;\n    background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(255, 255, 255, 0.05) 50%, rgba(0, 0, 0, 0) 100%);\n    opacity: 0.1;\n    position: absolute;\n    bottom: 100%;\n    animation: scanline 8s linear infinite;\n    pointer-events: none;\n  }\n\n  @keyframes scanline {\n    0% { bottom: 100%; }\n    100% { bottom: -100px; }\n  }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"2\">\n\n<main class=\"min-h-screen pb-20\" data-kid=\"3\">\n  \n  <header class=\"sticky top-0 z-50 bg-[#FDEE00] brutalist-border border-x-0 border-t-0 py-4 px-8 flex justify-between items-center mb-12\" data-kid=\"4\">\n    <div class=\"flex items-center gap-3\" data-kid=\"5\">\n      <div class=\"w-10 h-10 bg-[#111111] flex items-center justify-center brutalist-border\" data-kid=\"6\">\n        <i class=\"ti ti-activity text-[#00FF40] text-2xl\" data-kid=\"7\"></i>\n      </div>\n      <h1 class=\"font-anton text-2xl uppercase tracking-wider\" data-kid=\"8\">Infrastructure_Alert_v3</h1>\n    </div>\n    <div class=\"flex items-center gap-6 font-bold uppercase text-sm\" data-kid=\"9\">\n      <span class=\"flex items-center gap-2\" data-kid=\"10\"><span class=\"w-2 h-2 rounded-full bg-[#00FF40]\" data-kid=\"11\"></span> Server: Online</span>\n      <span class=\"bg-[#111111] text-white px-3 py-1\" data-kid=\"12\">Node: 127.0.0.1</span>\n    </div>\n  </header>\n\n  <div class=\"max-w-7xl mx-auto px-6 space-y-12 relative\" data-kid=\"13\">\n    \n    <div class=\"absolute -top-4 -left-4 text-4xl font-black opacity-20 pointer-events-none\" data-kid=\"14\">+</div>\n    <div class=\"absolute -top-4 -right-4 text-4xl font-black opacity-20 pointer-events-none\" data-kid=\"15\">+</div>\n    \n    \n    <section class=\"grid grid-cols-4 grid-rows-3 gap-6 h-[700px] reveal-item\" data-kid=\"16\">\n      \n      <div class=\"col-span-3 row-span-3 bg-white brutalist-border brutalist-shadow p-12 flex flex-col items-center justify-center relative overflow-hidden group hover-pop\" data-kid=\"17\">\n        <div class=\"absolute inset-0 grid-bg\" data-kid=\"18\"></div>\n        <div class=\"absolute top-6 left-6 brutalist-border px-4 py-2 bg-[#00FF40] font-black uppercase text-xl z-10\" data-kid=\"19\">\n          State: Healthy\n        </div>\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"absolute -top-16 -right-16 w-80 h-80 opacity-15 pointer-ev