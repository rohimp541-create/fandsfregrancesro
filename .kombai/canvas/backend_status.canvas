      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700;1,800;1,900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-bg: #FFFFFF;\n    --color-surface: #F2F3F4;\n    --color-text: #2A3439;\n    --color-olive: #9AB973;\n    --color-accent: #E60026; /* Scarlet for critical, though not used here as status is healthy */\n  }\n\n  body {\n    margin: 0;\n    font-family: 'Schibsted Grotesk', sans-serif;\n    background-color: var(--color-bg);\n    color: var(--color-text);\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .grid-lines {\n    background-image: \n      linear-gradient(to right, rgba(42, 52, 57, 0.05) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(42, 52, 57, 0.05) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .status-pulse {\n    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n  }\n\n  @keyframes pulse {\n    0%, 100% { opacity: 1; transform: scale(1); }\n    50% { opacity: 0.6; transform: scale(0.95); }\n  }\n\n</style>\n\n<div class=\"min-h-screen grid-lines selection:bg-[var(--color-olive)] selection:text-white\" data-kid=\"1\">\n  \n  <header class=\"border-b border-[var(--color-text)]/10 px-8 py-4 flex justify-between items-center bg-white/90 backdrop-blur sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"flex items-center gap-6\" data-kid=\"3\">\n      <span class=\"text-xs font-black tracking-[0.4em] uppercase\" data-kid=\"4\">System.Control</span>\n      <div class=\"h-4 w-px bg-[var(--color-text)]/20\" data-kid=\"5\"></div>\n      <span class=\"text-[10px] font-mono opacity-50 uppercase\" data-kid=\"6\">Session: A7-2204</span>\n    </div>\n    <div class=\"flex items-center gap-8\" data-kid=\"7\">\n      <nav class=\"flex gap-8 text-[10px] font-bold uppercase tracking-widest\" data-kid=\"8\">\n        <a href=\"#\" class=\"hover:opacity-60 transition-opacity\" data-kid=\"9\">Node Status</a>\n        <a href=\"#\" class=\"hover:opacity-60 transition-opacity\" data-kid=\"10\">Database</a>\n        <a href=\"#\" class=\"hover:opacity-60 transition-opacity\" data-kid=\"11\">Metrics</a>\n      </nav>\n      <div class=\"flex items-center gap-2\" data-kid=\"12\">\n        <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-olive)]\" data-kid=\"13\"></div>\n        <span class=\"text-[10px] font-bold uppercase tracking-tighter\" data-kid=\"14\">Live</span>\n      </div>\n    </div>\n  </header>\n\n  <main class=\"max-w-7xl mx-auto px-8 py-16 space-y-24\" data-kid=\"15\">\n    \n    \n    <section class=\"motion-reveal opacity-0\" data-kid=\"16\">\n      <div class=\"grid grid-cols-1 md:grid-cols-3 grid-rows-2 gap-px bg-[var(--color-text)]/10 border border-[var(--color-text)]/10\" data-kid=\"17\">\n        \n        <div class=\"md:col-span-2 md:row-span-2 bg-white p-12 lg:p-20 flex flex-col justify-center relative overflow-hidden group\" data-kid=\"18\">\n          <div class=\"absolute -right-20 -top-20 opacity-[0.03] pointer-events-none transition-transform duration-700 group-hover:rotate-12\" data-kid=\"19\">\n             <i class=\"ti ti-circle-check text-[320px]\" data-kid=\"20\"></i>\n          </div>\n          <div class=\"flex items-center gap-4 mb-10\" data-kid=\"21\">\n            <div class=\"w-5 h-5 rounded-full bg-[var(--color-olive)] status-pulse\" data-kid=\"22\"></div>\n            <span class=\"text-xs font-black tracking-[0.4em] uppercase\" data-kid=\"23\">Health: Operational</span>\n          </div>\n          <h1 class=\"text-6xl md:text-7xl lg:text-[9rem] font-black tracking-tighter leading-[0.85] mb-8\" data-kid=\"24\">\n            ONLINE<br data-kid=\"25\">\n            <span class=\"text-[var(--color-olive)]\" data-kid=\"26\">STABLE</span>\n          </h1>\n          <p class=\"text-lg lg:text-xl text-[var(--color-text)]/60 font-medium max-w-lg leading-snug\" data-kid=\"27\">\n            All backend systems reporting healthy status. Primary database connection latency at <span class=\"text-[var(--color-text)] font-bold\" data-kid=\"28\">0.08ms</span>.\n          </p>\n        </div>\n\n        \n        <div class=\"bg-[var(--color-surface)] p-10 flex flex-col justify-between border-b border-[var(--color-text)]/10 md:border-b-0\" data-kid=\"29\">\n          <div class=\"flex justify-between items-start\" data-kid=\"30\">\n            <div class=\"p-3 bg-white border border-[var(--color-text)]/5\" data-kid=\"31\">\n              <i class=\"ti ti-database text-3xl\" data-kid=\"32\"></i>\n            </div>\n            <span class=\"text-[10px] font-black px-2 py-1 bg-[var(--color-text)] text-white\" data-kid=\"33\">DB_UP</span>\n          </div>\n          <div data-kid=\"34\">\n            <div class=\"text-[10px] uppercase tracking-[0.2em] mb-2 font-bold opacity-40\" data-kid=\"35\">System Engine</div>\n            <div class=\"text-3xl font-black italic tracking-tighter leading-tight\" data-kid=\"36\">SQLite 3.45</div>\n            <div class=\"mt-2 h-1 w-full bg-white/50 relative overflow-hidden\" data-kid=\"37\">\n              <div class=\"absolute inset-y-0 left-0 bg-[var(--color-olive)] w-[98%]\" data-kid=\"38\"></div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"bg-white p-10 flex flex-col justify-between\" data-kid=\"39\">\n          <div class=\"p-3 bg-[var(--color-surface)] w-fit border border-[var(--color-text)]/5\" data-kid=\"40\">\n            <i class=\"ti ti-server text-3xl\" data-kid=\"41\"></i>\n          </div>\n          <div data-kid=\"42\">\n            <div class=\"text-[10px] uppercase tracking-[0.2em] mb-2 font-bold opacity-40\" data-kid=\"43\">Data Source Path</div>\n            <div class=\"text-sm font-mono break-all opacity-80 leading-relaxed\" data-kid=\"44\">\n              backend/data/store.db\n            </div>\n            <div class=\"mt-4 flex gap-1\" data-kid=\"45\">\n              <div class=\"h-1 flex-1 bg-[var(--color-text)]/5\" data-kid=\"46\"></div>\n              <div class=\"h-1 flex-1 bg-[var(--color-text)]/5\" data-kid=\"47\"></div>\n              <div class=\"h-1 flex-1 bg-[var(--color-text)]/5\" data-kid=\"48\"></div>\n              <div class=\"h-1 flex-1 bg-[var(--color-olive)]\" data-kid=\"49\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"motion-reveal opacity-0\" data-kid=\"50\">\n      <div class=\"flex items-baseline justify-between mb-16 border-b border-[var(--color-text)] pb-4\" data-kid=\"51\">\n        <h2 class=\"text-xs font-black tracking-[0.5em] uppercase\" data-kid=\"52\">01 // Entity Distribution</h2>\n        <span class=\"text-[10px] font-mono opacity-50 uppercase\" data-kid=\"53\">Weighted Analysis</span>\n      </div>\n\n      <div class=\"space-y-24\" data-kid=\"54\">\n        \n        <div class=\"group\" data-kid=\"55\">\n          <div class=\"flex items-end justify-between mb-6\" data-kid=\"56\">\n            <div class=\"space-y-1\" data-kid=\"57\">\n              <span class=\"text-xs font-black tracking-widest uppercase opacity-40\" data-kid=\"58\">Catalog Size</span>\n              <h3 class=\"text-5xl font-black tracking-tighter uppercase leading-none\" data-kid=\"59\">Products</h3>\n            </div>\n            <div class=\"text-right\" data-kid=\"60\">\n              <div class=\"text-9xl lg:text-[12rem] font-black text-[var(--color-olive)] tabular-nums leading-none -mb-4 tracking-tighter\" data-kid=\"61\">38</div>\n              <span class=\"text-[11px] font-black uppercase tracking-[0.3em] opacity-40\" data-kid=\"62\">Items Registered</span>\n            </div>\n          </div>\n          <div class=\"h-32 bg-[var(--color-surface)] relative overflow-hidden\" data-kid=\"63\">\n            <div id=\"progress-products\" class=\"absolute inset-y-0 left-0 w-full bg-[var(--color-text)] origin-left scale-x-0\" data-kid=\"64\"></div>\n            <div class=\"absolute inset-0 flex items-center justify-between px-6 pointer-events-none opacity-20\" data-kid=\"65\">\n              <span class=\"text-xs font-bold uppercase\" data-kid=\"66\">Min: 0</span>\n              <span class=\"text-xs font-bold uppercase\" data-kid=\"67\">Max Range: 100</span>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-16\" data-kid=\"68\">\n          \n          <div data-kid=\"69\">\n            <div class=\"flex items-end justify-between mb-4 border-b-2 border-[var(--color-text)] pb-2\" data-kid=\"70\">\n              <div class=\"space-y-1\" data-kid=\"71\">\n                <i class=\"ti ti-shield-check text-xl\" data-kid=\"72\"></i>\n                <span class=\"block text-[10px] font-black tracking-widest uppercase\" data-kid=\"73\">Admin Base</span>\n              </div>\n              <span class=\"text-4xl font-black tabular-nums\" data-kid=\"74\">01</span>\n            </div>\n            <div class=\"h-1.5 bg-[var(--color-surface)] relative overflow-hidden\" data-kid=\"75\">\n              <div id=\"progress-admins\" class=\"absolute inset-y-0 left-0 w-full bg-[var(--color-text)] origin-left scale-x-0\" data-kid=\"76\"></div>\n            </div>\n            <p class=\"mt-4 text-[11px] font-medium opacity-50 uppercase tracking-tight\" data-kid=\"77\">Active session: admin_root</p>\n          </div>\n\n          \n          <div class=\"opacity-40 grayscale\" data-kid=\"78\">\n            <div class=\"flex items-end justify-between mb-4 border-b-2 border-[var(--color-text)] pb-2\" data-kid=\"79\">\n              <div class=\"space-y-1\" data-kid=\"80\">\n                <i class=\"ti ti-users text-xl\" data-kid=\"81\"></i>\n                <span class=\"block text-[10px] font-black tracking-widest uppercase\" data-kid=\"82\">Customer Base</span>\n              </div>\n              <span class=\"text-4xl font-black tabular-nums\" data-kid=\"83\">00</span>\n            </div>\n            <div class=\"h-1.5 bg-[var(--color-surface)]\" data-kid=\"84\"></div>\n            <p class=\"mt-4 text-[11px] font-medium opacity-60 uppercase tracking-tight\" data-kid=\"85\">No consumer records</p>\n          </div>\n\n          \n          <div class=\"opacity-40 grayscale\" data-kid=\"86\">\n            <div class=\"flex items-end justify-between mb-4 border-b-2 border-[var(--color-text)] pb-2\" data-kid=\"87\">\n              <div class=\"space-y-1\" data-kid=\"88\">\n                <i class=\"ti ti-receipt-2 text-xl\" data-kid=\"89\"></i>\n                <span class=\"block text-[10px] font-black tracking-widest uppercase\" data-kid=\"90\">Transactions</span>\n              </div>\n              <span class=\"text-4xl font-black tabular-nums\" data-kid=\"91\">00</span>\n            </div>\n            <div class=\"h-1.5 bg-[var(--color-surface)]\" data-kid=\"92\"></div>\n            <p class=\"mt-4 text-[11px] font-medium opacity-60 uppercase tracking-tight\" data-kid=\"93\">Zero transactional delta</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"motion-reveal opacity-0\" data-kid=\"94\">\n      <div class=\"flex items-baseline justify-between mb-8\" data-kid=\"95\">\n        <h2 class=\"text-xs font-black tracking-[0.5em] uppercase\" data-kid=\"96\">02 // Schema Topology</h2>\n        <div class=\"flex gap-4\" data-kid=\"97\">\n          <button class=\"text-[10px] font-black uppercase tracking-widest border border-[var(--color-text)]/20 px-4 py-2 hover:bg-[var(--color-text)] hover:text-white transition-colors\" data-kid=\"98\">Export .CSV</button>\n          <button class=\"text-[10px] font-black uppercase tracking-widest bg-[var(--color-text)] text-white px-4 py-2\" data-kid=\"99\">Re-Index</button>\n        </div>\n      </div>\n\n      <div class=\"border border-[var(--color-text)]/10 overflow-hidden bg-white\" data-kid=\"100\">\n        <table class=\"w-full text-left border-collapse\" data-kid=\"101\">\n          <thead data-kid=\"102\">\n            <tr class=\"bg-[var(--color-surface)] border-b border-[var(--color-text)]/10\" data-kid=\"103\">\n              <th class=\"px-8 py-6 text-[10px] font-black uppercase tracking-widest\" data-kid=\"104\">Table Descriptor</th>\n              <th class=\"px-8 py-6 text-[10px] font-black uppercase tracking-widest\" data-kid=\"105\">Cardinality</th>\n              <th class=\"px-8 py-6 text-[10px] font-black uppercase tracking-widest\" data-kid=\"106\">Health State</th>\n              <th class=\"px-8 py-6 text-[10px] font-black uppercase tracking-widest\" data-kid=\"107\">Last Modified</th>\n              <th class=\"px-8 py-6 text-[10px] font-black uppercase tracking-widest text-right\" data-kid=\"108\">Access</th>\n            </tr>\n          </thead>\n          <tbody class=\"divide-y divide-[var(--color-text)]/5\" data-kid=\"109\">\n            <tr class=\"hover:bg-[var(--color-surface)]/50 group\" data-kid=\"110\">\n              <td class=\"px-8 py-8 font-mono text-sm tracking-tight text-[var(--color-text)]/80\" data-kid=\"111\">products</td>\n              <td class=\"px-8 py-8\" data-kid=\"112\">\n                <div class=\"flex items-baseline gap-2\" data-kid=\"113\">\n                  <span class=\"text-2xl font-black\" data-kid=\"114\">38</span>\n                  <span class=\"text-[10px] font-bold opacity-30\" data-kid=\"115\">ROW_ENTRIES</span>\n                </div>\n              </td>\n              <td class=\"px-8 py-8\" data-kid=\"116\">\n                <span class=\"inline-flex items-center gap-2 px-3 py-1 bg-[var(--color-olive)]/10 text-[var(--color-olive)] text-[10px] font-black uppercase tracking-widest\" data-kid=\"117\">\n                  <i class=\"ti ti-circle-check\" data-kid=\"118\"></i> Verified\n                </span>\n              </td>\n              <td class=\"px-8 py-8 text-[10px] font-bold opacity-50 uppercase\" data-kid=\"119\">2024.05.20 12:00</td>\n              <td class=\"px-8 py-8 text-right\" data-kid=\"120\">\n                <span class=\"text-[10px] font-black bg-[var(--color-text)]/5 px-2 py-1\" data-kid=\"121\">RW_SHARED</span>\n              </td>\n            </tr>\n            <tr class=\"hover:bg-[var(--color-surface)]/50 group\" data-kid=\"122\">\n              <td class=\"px-8 py-8 font-mono text-sm tracking-tight text-[var(--color-text)]/80\" data-kid=\"123\">admins</td>\n              <td class=\"px-8 py-8\" data-kid=\"124\">\n                <div class=\"flex items-baseline gap-2\" data-kid=\"125\">\n                  <span class=\"text-2xl font-black\" data-kid=\"126\">1</span>\n                  <span class=\"text-[10px] font-bold opacity-30\" data-kid=\"127\">ROW_ENTRIES</span>\n                </div>\n              </td>\n              <td class=\"px-8 py-8\" data-kid=\"128\">\n                <span class=\"inline-flex items-center gap-2 px-3 py-1 bg-[var(--color-olive)]/10 text-[var(--color-olive)] text-[10px] font-black uppercase tracking-widest\" data-kid=\"129\">\n                  <i class=\"ti ti-circle-check\" data-kid=\"130\"></i> Verified\n                </span>\n              </td>\n              <td class=\"px-8 py-8 text-[10px] font-bold opacity-50 uppercase\" data-kid=\"131\">2024.05.18 09:45</td>\n              <td class=\"px-8 py-8 text-right\" data-kid=\"132\">\n                <span class=\"text-[10px] font-black bg-[var(--color-text)]/5 px-2 py-1\" data-kid=\"133\">PRIVILEGED</span>\n              </td>\n            </tr>\n            <tr class=\"hover:bg-[var(--color-surface)]/50 group\" data-kid=\"134\">\n              <td class=\"px-8 py-8 font-mono text-sm tracking-tight text-[var(--color-text)]/80\" data-kid=\"135\">sqlite_sequence</td>\n              <td class=\"px-8 py-8\" data-kid=\"136\">\n                <div class=\"flex items-baseline gap-2\" data-kid=\"137\">\n                  <span class=\"text-2xl font-black opacity-40\" data-kid=\"138\">--</span>\n                </div>\n              </td>\n              <td class=\"px-8 py-8\" data-kid=\"139\">\n                <span class=\"inline-flex items-center gap-2 px-3 py-1 bg-[var(--color-text)]/5 text-[var(--color-text)]/60 text-[10px] font-black uppercase tracking-widest\" data-kid=\"140\">\n                  Internal System\n                </span>\n              </td>\n              <td class=\"px-8 py-8 text-[10px] font-bold opacity-40 uppercase\" data-kid=\"141\">No Data</td>\n              <td class=\"px-8 py-8 text-right\" data-kid=\"142\">\n                <span class=\"text-[10px] font-black bg-[var(--color-text)]/5 px-2 py-1\" data-kid=\"143\">READ_ONLY</span>\n              </td>\n            </tr>\n            <tr class=\"bg-[var(--color-surface)]/20\" data-kid=\"144\">\n              <td colspan=\"5\" class=\"px-8 py-4 text-[9px] font-bold opacity-30 uppercase tracking-[0.4em] text-center\" data-kid=\"145\">\n                End of Schema Output — Version 1.0.2 Stable\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"border-t border-[var(--color-text)]/10 p-8 flex flex-col md:flex-row justify-between items-center bg-white\" data-kid=\"146\">\n    <div class=\"flex items-center gap-12\" data-kid=\"147\">\n      <div class=\"space-y-1\" data-kid=\"148\">\n        <div class=\"text-[9px] font-black uppercase tracking-widest opacity-40\" data-kid=\"149\">Connection Pulse</div>\n        <div class=\"flex gap-1\" data-kid=\"150\">\n          <div class=\"w-1 h-3 bg-[var(--color-olive)]\" data-kid=\"151\"></div>\n          <div class=\"w-1 h-3 bg-[var(--color-olive)]\" data-kid=\"152\"></div>\n          <div class=\"w-1 h-3 bg-[var(--color-olive)]\" data-kid=\"153\"></div>\n          <div class=\"w-1 h-3 bg-[var(--color-olive)]\" data-kid=\"154\"></div>\n          <div class=\"w-1 h-3 bg-[var(--color-olive)]\" data-kid=\"155\"></div>\n          <div class=\"w-1 h-3 bg-[var(--color-text)]/10\" data-kid=\"156\"></div>\n        </div>\n      </div>\n      <div class=\"space-y-1\" data-kid=\"157\">\n        <div class=\"text-[9px] font-black uppercase tracking-widest opacity-40\" data-kid=\"158\">Environment</div>\n        <div class=\"text-[10px] font-bold\" data-kid=\"159\">PRODUCTION // EDGE_EU_WEST</div>\n      </div>\n    </div>\n    <div class=\"mt-8 md:mt-0 text-[9px] font-bold uppercase tracking-[0.5em] opacity-30\" data-kid=\"160\">\n      &copy; 2024 International Data Systems Corp.\n    </div>\n  </footer>\n</div>\n\n<script type=\"module\" data-kid=\"161\">\n  import { animate, inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  // Ensure initial visibility and then animate\n  document.querySelectorAll('.motion-reveal').forEach(el => {\n    inView(el, () => {\n      animate(el, { opacity: [0, 1], y: [40, 0] }, { duration: 0.8, ease: [0.22, 1, 0.36, 1] })\n    })\n  })\n\n  // Proportional progress bar fills\n  const productBar = document.getElementById(\"progress-products\");\n  if (productBar) {\n    inView(productBar, () => {\n      animate(productBar, { scaleX: [0, 0.38] }, { duration: 1.5, ease: \"circOut\", delay: 0.4 })\n    })\n  }\n\n  const adminBar = document.getElementById(\"progress-admins\");\n  if (adminBar) {\n    inView(adminBar, () => {\n      animate(adminBar, { scaleX: [0, 1] }, { duration: 1.2, ease: \"circOut\", delay: 0.8 })\n    })\n  }\n</script>\n",
