order-l-4 border-transparent hover:border-blue-400/50 cursor-pointer\" data-kid=\"35\">\n            <div class=\"flex items-center gap-3 text-blue-300/60 group-hover:text-blue-300\" data-kid=\"36\">\n              <span class=\"text-[10px] font-bold\" data-kid=\"37\">02</span>\n              <i class=\"ti ti-database\" data-kid=\"38\"></i>\n              <span class=\"text-sm font-bold tracking-widest uppercase\" data-kid=\"39\">Database</span>\n            </div>\n          </div>\n          <div class=\"nav-item group flex items-center justify-between p-4 hover:bg-[#1560BD]/10 border-l-4 border-transparent hover:border-blue-400/50 cursor-pointer\" data-kid=\"40\">\n            <div class=\"flex items-center gap-3 text-blue-300/60 group-hover:text-blue-300\" data-kid=\"41\">\n              <span class=\"text-[10px] font-bold\" data-kid=\"42\">03</span>\n              <i class=\"ti ti-users\" data-kid=\"43\"></i>\n              <span class=\"text-sm font-bold tracking-widest uppercase\" data-kid=\"44\">Users</span>\n            </div>\n          </div>\n          <div class=\"nav-item group flex items-center justify-between p-4 hover:bg-[#1560BD]/10 border-l-4 border-transparent hover:border-blue-400/50 cursor-pointer\" data-kid=\"45\">\n            <div class=\"flex items-center gap-3 text-blue-300/60 group-hover:text-blue-300\" data-kid=\"46\">\n              <span class=\"text-[10px] font-bold\" data-kid=\"47\">04</span>\n              <i class=\"ti ti-settings\" data-kid=\"48\"></i>\n              <span class=\"text-sm font-bold tracking-widest uppercase\" data-kid=\"49\">Config</span>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"connection-card bg-[#1560BD]/5 border border-[#1560BD]/20 p-6 relative overflow-hidden\" data-kid=\"50\">\n          <div class=\"absolute top-0 right-0 w-16 h-16 bg-[#39FF14]/5 -mr-8 -mt-8 rotate-45\" data-kid=\"51\"></div>\n          \n          <div class=\"flex flex-col gap-6\" data-kid=\"