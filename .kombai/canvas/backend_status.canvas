order-[#1560BD]/30 bg-[#010B13]\" data-kid=\"179\">\n                <div class=\"flex items-center gap-2\" data-kid=\"180\">\n                  <span class=\"text-[#39FF14] text-xs font-bold drop-shadow-[0_0_3px_rgba(57,255,20,0.5)]\" data-kid=\"181\">root@backend:~$</span>\n                  <span class=\"w-2 h-4 bg-[#39FF14] cursor-blink shadow-[0_0_8px_#39FF14]\" data-kid=\"182\"></span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"bottom-stats bg-[#1560BD]/5 border border-[#1560BD]/20 p-6\" data-kid=\"183\">\n          <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"184\">\n            <div class=\"space-y-2\" data-kid=\"185\">\n              <p class=\"text-[10px] text-blue-400 font-bold tracking-[0.2em] uppercase\" data-kid=\"186\">Security Level</p>\n              <div class=\"flex items-center gap-4\" data-kid=\"187\">\n                <div class=\"flex gap-1\" data-kid=\"188\">\n                  <div class=\"w-4 h-1 bg-[#39FF14] shadow-[0_0_5px_#39FF14]\" data-kid=\"189\"></div>\n                  <div class=\"w-4 h-1 bg-[#39FF14] shadow-[0_0_5px_#39FF14]\" data-kid=\"190\"></div>\n                  <div class=\"w-4 h-1 bg-[#39FF14] shadow-[0_0_5px_#39FF14]\" data-kid=\"191\"></div>\n                  <div class=\"w-4 h-1 bg-blue-900\" data-kid=\"192\"></div>\n                </div>\n                <span class=\"text-xs font-bold uppercase text-white\" data-kid=\"193\">Level 3 / Standard</span>\n              </div>\n            </div>\n            <div class=\"space-y-2\" data-kid=\"194\">\n              <p class=\"text-[10px] text-blue-400 font-bold tracking-[0.2em] uppercase\" data-kid=\"195\">Auth Tokens</p>\n              <div class=\"flex items-center gap-2\" data-kid=\"196\">\n                <span class=\"text-xs font-bold tabular-nums text-white\" data-kid=\"197\">1 Active</span>\n                <span class=\"text-[10px] text-blue-300/60 font-bold uppercase\" data-kid=\"198\">Expires in 2h</span>\n              </div>\n            </div>\n            <div class=\"space-y-2\" data-kid=\"199\">\n              <p class=\"text-[10px] text-blue-400 font-bold tracking-[0.2em] uppercase\" data-kid=\"200\">Raw Data Fragment</p>\n              <p class=\"text-xs text-blue-200/50 font-mono italic\" data-kid=\"201\">{\"products\":38, \"admins\":1, \"orders\":0, \"customers\":0}</p>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </main>\n\n  <style data-kid=\"202\">\n    @import url('https://fonts.googleapis.com/css2?family=Inconsolata:wght@400;700;900&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .custom-scrollbar::-webkit-scrollbar {\n      width: 3px;\n    }\n    .custom-scrollbar::-webkit-scrollbar-track {\n      background: transparent;\n    }\n    .custom-scrollbar::-webkit-scrollbar-thumb {\n      background: rgba(57, 255, 20, 0.2);\n      border-radius: 10px;\n    }\n    .custom-scrollbar::-webkit-scrollbar-thumb:hover {\n      background: rgba(57, 255, 20, 0.4);\n    }\n\n    /* For smooth layout animations */\n    .visualizer-bar {\n      transition: height 1s ease-in-out;\n    }\n\n    .crt-overlay {\n      background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));\n      background-size: 100% 2px, 3px 100%;\n      pointer-events: none;\n    }\n\n    .crt-scanline {\n      width: 100%;\n      height: 100px;\n      z-index: 100;\n      background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(57, 255, 20, 0.03) 50%, rgba(0, 0, 0, 0) 100%);\n      opacity: 0.08;\n      position: absolute;\n      bottom: 100%;\n      animation: scanline 12s linear infinite;\n    }\n\n    @keyframes scanline {\n      0% { bottom: 100%; }\n      100% { bottom: -100px; }\n    }\n\n    .cursor-blink {\n      animation: blink 1s step-end infinite;\n    }\n\n    @keyframes blink {\n      50% { opacity: 0; }\n    }\n  </style>\n\n  <div class=\"crt-overlay fixed inset-0 pointer-events-none z-50\" data-kid=\"203\"></div>\n  <div class=\"crt-scanline pointer-events-none\" data-kid=\"204\"></div>\n\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"205\"></script>\n  <script type=\"module\" data-kid=\"206\">\n    import { animate, stagger, inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n    import { animate as animeAnimate } from 'https://esm.sh/animejs@4';\n\n    // Dashboard Load Sequence (GSAP)\n    const tl = gsap.timeline({ defaults: { ease: \"power4.out\", duration: 0.8 } });\n    \n    tl.from(\".dashboard-header\", { autoAlpha: 0, y: -30 })\n      .from(\".nav-item\", { autoAlpha: 0, x: -20, stagger: 0.1 }, \"-=0.4\")\n      .from(\".connection-card\", { autoAlpha: 0, scale: 0.95 }, \"-=0.4\")\n      .from(\".kpi-card\", { autoAlpha: 0, y: 20, stagger: 0.08, scale: 0.9 }, \"-=0.6\")\n      .from(\".chart-container\", { autoAlpha: 0, y: 30 }, \"-=0.5\")\n      .from(\".log-entry\", { autoAlpha: 0, x: 10, stagger: 0.05 }, \"-=0.5\")\n      .from(\".bottom-stats\", { autoAlpha: 0, y: 20 }, \"-=0.4\");\n\n    // Anime.js: Pulse Healthy Indicator\n    animeAnimate(\".pulse-ring\", {\n      scale: [1, 2.8],\n      opacity: [0.7, 0],\n      duration: 3500,\n      easing: 'easeOutExpo',\n      loop: true\n    });\n\n    // Pulse Breathe for the actual dot\n    animeAnimate(\".pulse-indicator .w-3\", {\n      scale: [1, 1.2],\n      duration: 1000,\n      direction: 'alternate',\n      easing: 'easeInOutSine',\n      loop: true\n    });\n\n    // Count-up for stats\n    document.querySelectorAll('.stat-number').forEach(el => {\n      inView(el, () => {\n        const target = parseInt(el.getAttribute('data-target'));\n        if (target === 0) return;\n        animate(0, target, {\n          duration: 1.5,\n          onUpdate: v => el.textContent = Math.round(v)\n        });\n      });\n    });\n\n    // Randomize visualizer bars for \"live\" feel\n    setInterval(() => {\n      document.querySelectorAll('.visualizer-bar').forEach(bar => {\n        const newHeight = Math.floor(Math.random() * 70) + 20;\n        bar.style.height = `${newHeight}%`;\n      });\n    }, 2000);\n  </script>\n</div>\n",
